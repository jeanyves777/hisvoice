# ============================================================
# HIS VOICE — Production Environment Variables
# Copy to .env on VPS and fill in values
# ============================================================

# Domain
DOMAIN=hisvoice.app
NEXTAUTH_URL=https://hisvoice.app

# Database
DB_PASSWORD=change-this-to-a-strong-password

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Ollama AI
OLLAMA_MODEL=llama3.1

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@hisvoice.app

# Meilisearch
MEILI_MASTER_KEY=change-this-to-a-strong-key

# Umami Analytics
UMAMI_SECRET=change-this-to-a-strong-secret
