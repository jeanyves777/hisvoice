# ============================================================
# HIS VOICE — Environment Variables Template
# Copy to .env and fill in values
# ============================================================

# Database
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/hisvoice"  # production

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Telegram Alerts
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Email / SMTP
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@hisvoice.app"

# IP Geolocation
GEO_API_URL="http://ip-api.com/json"
